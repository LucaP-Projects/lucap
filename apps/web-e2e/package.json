{
  "name": "@lucap/web-e2e",
  "version": "1.0.0",
  "description": "E2E tests for the LucaP web application using Playwright",
  "private": true,
  "scripts": {
    "test": "echo 'E2E tests require services running. Use test:e2e instead.' && exit 0",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen http://localhost:3000"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.3.1",
    "typescript": "^5.0.0"
  }
}
