# Web E2E Test Configuration (Playwright)
# Copy this file to .env and fill in the values

# Web URL (where the Next.js app is running)
# Local:   http://localhost:3000
# Staging: https://staging.lucap.com
WEB_URL=http://localhost:3000

# =============================================================================
# Test Safety Controls
# =============================================================================

# Allow destructive tests on staging/production (default: false)
# ALLOW_DESTRUCTIVE_TESTS=true
