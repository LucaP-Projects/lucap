  billPaymentId       String?
  vendorCreditId      String?
  purchaseId          String?
  purchaseOrderId     String?
  type                TransactionType
  updatedAt           DateTime                @updatedAt
  status              TransactionStatus       @default(INCOMPLETE)
  approvedByUser      User?                   @relation("ApprovedTransactions", fields: [approvedBy], references: [id])
  category            TransactionCategory?    @relation("CategoryTransactions", fields: [categoryId], references: [id])
  company             Company                 @relation(fields: [companyId], references: [id])
  createdByUser       User                    @relation("UserTransactions", fields: [createdBy], references: [id])
  creditMemo          CreditMemo?             @relation(fields: [creditMemoId], references: [id])
  invoicePayment      Payment?                @relation(fields: [invoicePaymentId], references: [id])
  refundReceipt       RefundReceipt?          @relation(fields: [refundReceiptId], references: [id])
  salesReceipt        SalesReceipt?           @relation(fields: [salesReceiptId], references: [id])
  bill                Bill?                   @relation(fields: [billId], references: [id])
  billPayment         BillPayment?            @relation(fields: [billPaymentId], references: [id])
  vendorCredit        VendorCredit?           @relation(fields: [vendorCreditId], references: [id])
  purchase            Purchase?               @relation(fields: [purchaseId], references: [id])
  purchaseOrder       PurchaseOrder?          @relation(fields: [purchaseOrderId], references: [id])
  attachments         TransactionAttachment[]
  transactionHistory  TransactionHistory[]

  @@index([type])
  @@index([categoryId])
  @@index([date])
  @@index([createdBy])
  @@index([status])
  @@index([completed])
  @@index([billId])
  @@index([billPaymentId])
  @@index([vendorCreditId])
  @@index([purchaseId])
  @@index([purchaseOrderId])
}





