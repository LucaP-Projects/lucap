// Accountant organization: represents an accounting firm or profile that manages multiple client companies.
model Accountant {
  id        String           @id @default(cuid())
  name      String
  slug      String?          @unique
  ownerId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  owner     User?            @relation("AccountantOwner", fields: [ownerId], references: [id])
  users     AccountantUser[]
  assignments AccountantAssignment[]

  @@index([ownerId])
}

// Users that belong to an Accountant profile (accounting staff)
model AccountantUser {
  id           String              @id @default(cuid())
  accountantId String
  userId       String
  role         AccountantUserRole  @default(MEMBER)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  accountant   Accountant          @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments  AccountantAssignment[]

  @@unique([accountantId, userId])
  @@index([accountantId])
  @@index([userId])
}

enum AccountantUserRole {
  OWNER
  ADMIN
  MEMBER
}

// Assignment of an accountant (or accountant user) to a client company with optional per-user permissions
model AccountantAssignment {
  id               String         @id @default(cuid())
  accountantId     String
  accountantUserId String?
  companyId        String
  permissions      Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  accountant       Accountant     @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  accountantUser   AccountantUser? @relation(fields: [accountantUserId], references: [id])
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([accountantId, companyId])
  @@index([accountantId])
  @@index([companyId])
  @@index([accountantUserId])
}


model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Ticket {
  id          String    @id @default(uuid())
  title       String
  service     String?
  channel     String?
  status      String    @default("OPEN")
  companyId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  messages    Message[]
  company     Company?  @relation(fields: [companyId], references: [id])
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@map("ticket")
}

model Message {
  id                 String              @id @default(uuid())
  ticketId           String
  author             String?
  message            String
  type               String              @default("text")
  date               DateTime            @default(now())
  ticket             Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messageAttachments MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model CompanyFormationRequest {
  id              String   @id @default(uuid())
  status          String   @default("SUBMITTED")
  companyType     String?
  companyName     String?
  taxId           String?
  email           String?
  phone           String?
  website         String?
  address         Json?
  taxRegime       String?
  vatRegime       String?
  capitalAmount   Float?
  numberOfShares  Int?
  shareholders    Json?
  notes           String?

  // Submitter — either a platform user or external contact
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  submitterName   String?
  submitterEmail  String?
  submitterPhone  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("company_formation_request")
}

