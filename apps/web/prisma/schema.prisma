generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

generator json {
  provider = "prisma-json-types-generator"
}

// ---- Enums ----

enum UserRole {
  USER
  ADMIN
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum AddressType {
  BILLING
  SHIPPING
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountApplicationTime {
  BEFORE_TAX
  AFTER_TAX
}

enum IntervalUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum TaxStatus {
  ACTIVE
  INACTIVE
}

enum TaxType {
  SALES
  VAT
  GST
  SERVICE
  OTHER
}

enum ReceiptStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

enum AdjustmentStrategy {
  DISTRIBUTE_TO_FUTURE
  APPEND_TO_REMAINING
  LAST_INSTALLMENT
  NEXT_INSTALLMENT
  WEIGHTED_DISTRIBUTION
  PROPORTIONAL_REMAINING
  FIXED_FIRST
  CUSTOM
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_CANCELLED
  CUSTOMER_WELCOME
}

enum ChargeStatus {
  PENDING
  INVOICED
  CANCELED
}

enum CreditStatus {
  PENDING
  CREDITED
  CANCELED
}

enum VersionChangeType {
  PRICE_ADJUSTMENT
  INTERVAL_CHANGE
  INSTALLMENT_RESTRUCTURE
  INITIAL_FEE_ADJUSTMENT
}

enum VersionStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  PENDING_ACTIVATION
}

enum Permission {
  MANAGE_CUSTOMERS
  MANAGE_SUBSCRIPTIONS
  MANAGE_PAYMENTS
  VIEW_REPORTS
  MANAGE_SETTINGS
  MANAGE_STAFF
  MANAGE_TEMPLATES
  VIEW_DASHBOARD
  MANAGE_FILES
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  DIGITAL_WALLET
  MOBILE_PAYMENT
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
}

enum PaymentFrequency {
  ONE_TIME
  SUBSCRIPTION
  INSTALLMENTS
}

enum SystemRole {
  ADMIN
  CUSTOMER
  STAFF
  SUPER_ACCOUNTANT
  ACCOUNTANT_STAFF
}

enum TransactionType {
  EXPENSE
  REVENUE
  WITHDRAWAL
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum CreditMemoStatus {
  DRAFT
  ISSUED
  APPLIED // When applied to an invoice
  VOID // If cancelled/voided
}

enum CreditMemoReason {
  RETURN // Product return
  OVERPAYMENT // Customer paid too much
  CANCELLATION // Service/product cancellation
  CORRECTION // Billing error correction
  DISCOUNT // Post-sale discount
  DAMAGED_GOODS // Products received damaged
  OTHER // Other reasons
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  VOID
  INCOMPLETE
}

enum RefundStatus {
  PENDING
  PROCESSED
  REJECTED
  CANCELLED
}

enum RefundReason {
  DEFECTIVE_PRODUCT
  WRONG_ITEM
  OTHER
  NOT_SATISFIED
  DUPLICATE_CHARGE
  SHIPPING_ISSUE
  PRICING_ERROR
}

enum TableType {
  CUSTOMER
  INVOICE
  PAYMENT
  TRANSACTION
}

enum CustomFieldType {
  TEXT_AND_NUMBER
  NUMBER
  DATE
  DROPDOWN_LIST
}

enum CustomFieldCategory {
  CUSTOMER
  TRANSACTION
  VENDOR
  PROJECT
}

enum ItemType {
  SERVICE
  NON_INVENTORY
  INVENTORY
}

enum CustomFieldFormType {
  SALES_RECEIPT
  INVOICE
  ESTIMATE
  CREDIT_MEMO
  REFUND_RECEIPT
  PURCHASE_ORDER
  EXPENSE
  BILL
  CHECK
  VENDOR_CREDIT
  CREDIT_CARD_CREDIT
}

enum CustomerPreferredPaymentMethod {
  PRINT
  EMAIL
  NONE
}

enum CompanyType {
  SARL
  SUARL
  SA
  SCA
}

// ---- Models ----

model User {
  id                   String        @id @default(uuid())
  email                String        @unique
  name                 String
  password             String?
  emailVerified        Boolean       @default(false)
  image                String?
  role                 UserRole      @default(USER)
  banned               Boolean?
  banReason            String?
  banExpires           DateTime?
  customer             Customer?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  createdTransactions  Transaction[] @relation("UserTransactions")
  approvedTransactions Transaction[] @relation("ApprovedTransactions")
  companies            UserCompany[]
  sessions             Session[]

  activeCompanyId     String?
  activeCompany       Company?  @relation("ActiveCompany", fields: [activeCompanyId], references: [id])
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  tickets             Ticket[]

  useraccounts UserAccount[]

  @@index([activeCompanyId])
  @@map("users")
}

model UserAccount {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Foreign key relation to User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([providerId])
  @@map("UserAccount")
}

model UserCompany {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  role      Role    @relation(fields: [roleId], references: [id])
  roleId    String

  isActive  Boolean  @default(true)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([roleId])
  @@index([isActive])
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  systemRole  SystemRole? // For system-defined roles
  permissions Permission[]
  company     Company      @relation(fields: [companyId], references: [id])
  companyId   String

  // Role hierarchy (optional)
  parentRoleId String?
  parentRole   Role?   @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles   Role[]  @relation("RoleHierarchy")

  // User assignments
  userCompanies UserCompany[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId])
  @@index([companyId])
  @@index([isActive])
  @@index([parentRoleId])
  @@index([systemRole])
}

model Customer {
  id              String        @id @default(cuid())
  displayName     String        @db.VarChar(500)
  title           String?       @db.VarChar(16)
  givenName       String?       @db.VarChar(100)
  middleName      String?       @db.VarChar(100)
  familyName      String?       @db.VarChar(100)
  suffix          String?       @db.VarChar(16)
  companyName     String?       @db.VarChar(100)
  customerType    CustomerType? @relation("CustomerType", fields: [customerTypeId], references: [id])
  customerTypeId  String?
  // Contact Details  
  primaryPhone    String?       @db.VarChar(30)
  alternatePhone  String?       @db.VarChar(30)
  mobile          String?       @db.VarChar(30)
  fax             String?       @db.VarChar(30)
  primaryEmail    String?
  webAddress      String?       @db.VarChar(1000)
  /// [Address]
  billingAddress  Json?
  /// [Address]  
  shippingAddress Json?

  // Business Details
  taxIdentifier  String? // Masked in responses, showing last 5 chars
  secondaryTaxId String? // Masked in responses, showing last 5 chars
  resaleNumber   String? @db.VarChar(16)
  businessNumber String? @db.VarChar(10)
  notes          String? @db.VarChar(2000)

  // Financial Details
  balance                Float                           @default(0)
  creditLimit            Float?
  preferredPaymentMethod CustomerPreferredPaymentMethod? // Print, Email, or None
  taxable                Boolean                         @default(true)
  printOnCheckName       String?                         @db.VarChar(110)

  parentCustomer Customer?  @relation("CustomerHierarchy", fields: [parentId], references: [id])
  parentId       String?
  subCustomers   Customer[] @relation("CustomerHierarchy")
  level          Int        @default(0) // Max value: 4 (5 levels total)

  status   CustomerStatus @default(ACTIVE)
  /// [CustomerMetadata]
  metadata Json?
  user     User?          @relation(fields: [userId], references: [id])
  userId   String?        @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerPaymentEvents CustomerPaymentEvent[]
  invoices              Invoice[]
  payments              Payment[]
  estimates             Estimate[]
  creditMemos           CreditMemo[]
  salesReceipts         SalesReceipt[]
  refundReceipts        RefundReceipt[]
  delayedCharges        DelayedCharge[]
  delayedCredits        DelayedCredit[]
  company               Company                @relation(fields: [companyId], references: [id])
  companyId             String
  journalEntry          JournalEntry[]

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([displayName, companyId])
  @@index([parentId])
  @@index([status])
  @@index([displayName])
}

model CustomerType {
  id        String     @id @default(cuid())
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  customer  Customer[] @relation("CustomerType")
  company   Company    @relation(fields: [companyId], references: [id])
  companyId String

  @@unique([name, companyId])
}

model Account {
  id              String   @id @default(cuid())
  title           String
  number          String
  composed_number String
  is_custom       Boolean  @default(false)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Self-relation for account hierarchy
  parent_id String?
  parent    Account?  @relation("AccountToAccount", fields: [parent_id], references: [id], onDelete: SetNull)
  children  Account[] @relation("AccountToAccount")

  // Template relation
  template   AccountTemplate? @relation(fields: [templateId], references: [id])
  templateId String?

  // Company relation
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  // Item relations
  incomeItems         Item[]             @relation("ItemIncomeAccount")
  expenseItems        Item[]             @relation("ItemExpenseAccount")
  inventoryAssetItems Item[]             @relation("ItemInventoryAssetAccount")
  journalEntryLine    JournalEntryLine[]
  isActive            Boolean            @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([companyId, number])
  @@unique([companyId, composed_number])
  @@index([parent_id])
  @@index([templateId])
  @@index([companyId])
}

model PaymentEvent {
  id                    String                 @id @default(cuid())
  type                  PaymentFrequency
  customerPaymentEvents CustomerPaymentEvent[]
  active                Boolean                @default(true)
  versionId             String?                @unique
  currentVersion        PaymentEventVersion?   @relation("CurrentVersion", fields: [versionId], references: [id])
  versions              PaymentEventVersion[]  @relation("AllVersions")
  updatedAt             DateTime               @updatedAt
  createdAt             DateTime               @default(now())
  company               Company                @relation(fields: [companyId], references: [id])
  companyId             String
  isActive              Boolean                @default(true)
  deactivatedAt         DateTime?
  deactivatedByUserId   String?
  deactivationReason    String?

  @@index([active])
  @@index([versionId])
}

model PaymentEventVersion {
  id                      String                 @id @default(cuid())
  paymentEventId          String?
  paymentEvent            PaymentEvent?          @relation("AllVersions", fields: [paymentEventId], references: [id])
  currentForPaymentEvent  PaymentEvent?          @relation("CurrentVersion")
  items                   PaymentEventItem[]
  version                 Int
  name                    String
  description             String?
  type                    PaymentFrequency
  status                  VersionStatus          @default(DRAFT)
  scheduledActivationDate DateTime?
  activatedAt             DateTime?
  /// [PaymentSettings]
  paymentSettings         Json
  customerPaymentEvents   CustomerPaymentEvent[]
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([paymentEventId, version])
  @@index([paymentEventId])
  @@index([type])
}

model CustomerPaymentEvent {
  id             String              @id @default(cuid())
  paymentEvent   PaymentEvent        @relation(fields: [paymentEventId], references: [id])
  paymentEventId String
  version        PaymentEventVersion @relation(fields: [versionId], references: [id])
  versionId      String
  customer       Customer?           @relation(fields: [customerId], references: [id])
  customerId     String?

  startDate DateTime
  endDate   DateTime?
  status    PaymentStatus @default(PENDING)
  credit    Float         @default(0)

  /// [PaymentProgress]
  progress Json // Progress tracking

  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([customerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model PaymentEventItem {
  id          String              @id @default(cuid())
  version     PaymentEventVersion @relation(fields: [versionId], references: [id])
  versionId   String
  productName String
  description String?
  quantity    Float
  rate        Float
  sku         String?
  amount      Float
  taxable     Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  item        Item?               @relation(fields: [itemId], references: [id])
  itemId      String?

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([versionId])
}

model Category {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(50)
  description String? @db.VarChar(200)

  // Hierarchical structure
  parentId      String?
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories Category[] @relation("CategoryHierarchy")
  level         Int        @default(0) // To track hierarchy depth

  // Relationships
  items Item[]

  // Metadata
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String

  isActive            Boolean           @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  categoryProduct     CategoryProduct[]

  @@index([name, companyId])
  @@index([parentId])
  @@index([active])
  @@index([level])
  @@index([sortOrder])
}

model Item {
  id   String   @id @default(cuid())
  type ItemType
  name String   @db.VarChar(100)
  sku  String?  @db.VarChar(50)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  description         String? @db.VarChar(1000)
  salesDescription    String? @db.VarChar(1000)
  purchaseDescription String? @db.VarChar(1000)

  // Sales Information
  sellable       Boolean   @default(true)
  salesPrice     Float     @default(0.00)
  salesTaxable   Boolean   @default(true)
  salesStartDate DateTime?
  salesEndDate   DateTime?

  // Discount fields for item
  discountType            DiscountType?
  discountValue           Float?
  discountApplicationTime DiscountApplicationTime?
  discountAmount          Float                    @default(0)

  // Purchase Information
  purchasable       Boolean   @default(false)
  cost              Float?
  preferredVendorId String?
  lastPurchasePrice Float?
  lastPurchaseDate  DateTime?

  // Inventory Specific Fields
  trackInventory          Boolean   @default(false)
  quantityOnHand          Int?
  reorderPoint            Int?
  initialQuantity         Int?
  asOfDate                DateTime?
  // Accounting Relationships
  incomeAccountId         String?
  expenseAccountId        String?
  inventoryAssetAccountId String?

  incomeAccount         Account? @relation("ItemIncomeAccount", fields: [incomeAccountId], references: [id])
  expenseAccount        Account? @relation("ItemExpenseAccount", fields: [expenseAccountId], references: [id])
  inventoryAssetAccount Account? @relation("ItemInventoryAssetAccount", fields: [inventoryAssetAccountId], references: [id])

  // Related Document Items
  invoiceItems      InvoiceItem[]
  estimateItems     EstimateItem[]
  creditMemoItems   CreditMemoItem[]
  salesReceiptItems SalesReceiptItem[]
  refundItems       RefundReceiptItem[]
  chargeItems       DelayedChargeItem[]
  creditItems       DelayedCreditItem[]
  paymentEventItems PaymentEventItem[]

  // Image/Attachment handling
  imageUrl String? @db.VarChar(2000)

  /// [ItemMetadata]
  metadata  Json?
  status    ItemStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id])
  companyId String

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  product             Product[]

  @@unique([sku, companyId])
  @@index([type])
  @@index([status])
  @@index([categoryId])
  @@index([sku])
  @@index([sellable])
  @@index([purchasable])
  @@index([trackInventory])
  @@index([name, description])
}

model InvoiceItem {
  id                  String    @id @default(cuid())
  invoice             Invoice   @relation(fields: [invoiceId], references: [id])
  invoiceId           String
  productName         String // Or product relation if you have a products table
  description         String?
  quantity            Float
  rate                Float
  amount              Float
  sku                 String?
  taxable             Boolean   @default(true)
  createdAt           DateTime  @default(now())
  // Add this lines to track changes
  // status      PaymentStatus @default(PENDING)
  // paidAmount  Float         @default(0) 
  updatedAt           DateTime  @updatedAt
  item                Item?     @relation(fields: [itemId], references: [id])
  itemId              String?
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([invoiceId])
}

model Invoice {
  id                      String                   @id @default(cuid())
  convertedFromEstimate   Boolean                  @default(false)
  estimateId              String?
  estimate                Estimate?                @relation(fields: [estimateId], references: [id])
  number                  String
  customer                Customer                 @relation(fields: [customerId], references: [id])
  customerId              String
  customerPaymentEvent    CustomerPaymentEvent?    @relation(fields: [paymentEventId], references: [id])
  paymentEventId          String?
  discountType            DiscountType? // For PERCENTAGE or FIXED_AMOUNT
  discountValue           Float? // The actual discount value (e.g., 10 for 10% or 50 for $50)
  taxRate                 Float                    @default(0)
  discountApplicationTime DiscountApplicationTime? // BEFORE_TAX or AFTER_TAX
  discountAmount          Float                    @default(0) // The calculated discount amount
  amount                  Float
  dueDate                 DateTime
  status                  PaymentStatus            @default(PENDING)
  notes                   String?
  emailCustomer           String?
  taxId                   String?
  tax                     TaxRate?                 @relation(fields: [taxId], references: [id])
  taxAmount               Float                    @default(0)
  /// [PaymentEventSnapshot]
  paymentEventSnapshot    Json
  payments                Payment[]
  items                   InvoiceItem[] // Add this line to connect to invoice items
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  isLinkedToVersion       Boolean                  @default(false)
  attachments             InvoiceAttachment[]

  // refunds               RefundReceipt[]
  company    Company      @relation(fields: [companyId], references: [id])
  companyId  String
  creditMemo CreditMemo[]

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([number, companyId])
  @@index([estimateId])
  @@index([customerId])
  @@index([paymentEventId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceAttachment {
  id                  String    @id @default(cuid())
  invoice             Invoice   @relation(fields: [invoiceId], references: [id])
  invoiceId           String
  file                File      @relation(fields: [fileId], references: [id])
  fileId              String
  createdAt           DateTime  @default(now())
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([invoiceId, fileId])
  @@index([invoiceId])
  @@index([fileId])
}

model EstimateItem {
  id                  String    @id @default(cuid())
  estimate            Estimate  @relation(fields: [estimateId], references: [id])
  estimateId          String
  productName         String
  description         String?
  quantity            Float
  rate                Float
  amount              Float
  sku                 String?
  taxable             Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  item                Item?     @relation(fields: [itemId], references: [id])
  itemId              String?
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([estimateId])
}

model Estimate {
  id                      String                   @id @default(cuid())
  number                  String
  customer                Customer                 @relation(fields: [customerId], references: [id])
  customerId              String
  amount                  Float
  dueDate                 DateTime
  taxRate                 Float                    @default(0)
  discountType            DiscountType? // For PERCENTAGE or FIXED_AMOUNT
  discountValue           Float? // The actual discount value (e.g., 10 for 10% or 50 for $50)
  discountApplicationTime DiscountApplicationTime? // BEFORE_TAX or AFTER_TAX
  discountAmount          Float                    @default(0) // The calculated discount amount
  status                  EstimateStatus           @default(DRAFT)
  notes                   String?
  emailCustomer           String?
  taxId                   String?
  tax                     TaxRate?                 @relation(fields: [taxId], references: [id])
  taxAmount               Float                    @default(0)
  items                   EstimateItem[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  validUntil              DateTime? // New field: Optional expiration date
  convertedToInvoice      Boolean                  @default(false) // New field: Track if converted to invoice
  invoiceId               String? // New field: Reference to invoice if converted
  attachments             EstimateAttachment[]
  /// [PaymentEventSnapshot]
  paymentEventSnapshot    Json
  invoices                Invoice[]
  company                 Company                  @relation(fields: [companyId], references: [id])
  companyId               String

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([number, companyId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model EstimateAttachment {
  id         String   @id @default(cuid())
  estimate   Estimate @relation(fields: [estimateId], references: [id])
  estimateId String
  file       File     @relation(fields: [fileId], references: [id])
  fileId     String
  createdAt  DateTime @default(now())

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([estimateId, fileId])
  @@index([estimateId])
  @@index([fileId])
}

model CreditMemoItem {
  id                  String     @id @default(cuid())
  creditMemo          CreditMemo @relation(fields: [creditMemoId], references: [id])
  creditMemoId        String
  productName         String
  description         String?
  quantity            Float
  sku                 String?
  rate                Float
  amount              Float
  taxable             Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  item                Item?      @relation(fields: [itemId], references: [id])
  itemId              String?
  isActive            Boolean    @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([creditMemoId])
}

model CreditMemo {
