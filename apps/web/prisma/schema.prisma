  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId  String

  entries JournalEntryLine[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  // Remove the unique constraint to allow duplicate numbers
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([companyId])
  @@index([customerId])
  @@index([date])
  @@index([journalNo])
}

model JournalEntryLine {
  id          String  @id @default(cuid())
  debit       Float?
  credit      Float?
  description String?

  // Relations
  account             Account      @relation(fields: [accountId], references: [id])
  accountId           String
  journalEntry        JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId      String
  isActive            Boolean      @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@index([accountId])
  @@index([journalEntryId])
}

model TaxRate {
  id          String  @id @default(cuid())
  name        String
  description String?
  agencyName  String
  type        TaxType @default(SALES)
  rate        Float
  company     Company @relation(fields: [companyId], references: [id])
  companyId   String

  status        TaxStatus @default(ACTIVE)
  effectiveDate DateTime  @default(now())
  endDate       DateTime?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  invoices       Invoice[]
  estimates      Estimate[]
  creditMemos    CreditMemo[]
  salesReceipts  SalesReceipt[]
  refundReceipts RefundReceipt[]
  delayedCharges DelayedCharge[]
  delayedCredits DelayedCredit[]

  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?

  @@unique([name, companyId])
  @@index([status])
  @@index([companyId])
  @@index([effectiveDate])
}

model Company {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  companyType CompanyType?
  legalName   String?
  taxId       String?
  email       String?
  phone       String?
  website     String?
  /// [Address]
  address     Json?
  logo        String?

  // Status and Settings
  isActive Boolean @default(true)
  settings Json?
  metadata Json?

  parentCompanyId String?
  parentCompany   Company?  @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id])
  subsidiaries    Company[] @relation("CompanyHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserCompany[]
  activeUsers User[]        @relation("ActiveCompany")

  roles Role[]

  customers      Customer[]
  invoices       Invoice[]
  payments       Payment[]
  transactions   Transaction[]
  items          Item[]
  accounts       Account[]
  estimates      Estimate[]
  creditMemos    CreditMemo[]
  salesReceipts  SalesReceipt[]
  refundReceipts RefundReceipt[]
  delayedCharges DelayedCharge[]
  delayedCredits DelayedCredit[]
  categories     Category[]
  customerTypes  CustomerType[]
  paymentEvents  PaymentEvent[]
  customFields   CustomField[]
  emailTemplates EmailTemplate[]
  files          File[]
  journalEntry   JournalEntry[]
  taxRates       TaxRate[]
  products       Product[]
  store          Store?
  tickets        Ticket[]

  @@index([isActive])
  @@index([parentCompanyId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Ticket {
  id          String    @id @default(uuid())
  title       String
  service     String?
  channel     String?
  status      String    @default("OPEN")
  messages    Message[]
  company     Company?  @relation(fields: [companyId], references: [id])
  companyId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User?     @relation(fields: [createdById], references: [id])
  createdById String?

  @@map("ticket")
}

model Message {
  id                 String              @id @default(uuid())
  ticketId           String
  ticket             Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author             String?
  message            String
  type               String              @default("text")
  date               DateTime            @default(now())
  messageAttachments MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())
}
