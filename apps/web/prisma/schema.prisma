  name                String
  description         String?
  agencyName          String
  type                TaxType         @default(SALES)
  rate                Float
  companyId           String
  status              TaxStatus       @default(ACTIVE)
  effectiveDate       DateTime        @default(now())
  endDate             DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  isActive            Boolean         @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  creditMemos         CreditMemo[]
  delayedCharges      DelayedCharge[]
  delayedCredits      DelayedCredit[]
  estimates           Estimate[]
  invoices            Invoice[]
  refundReceipts      RefundReceipt[]
  salesReceipts       SalesReceipt[]
  company             Company         @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
  @@index([status])
  @@index([companyId])
  @@index([effectiveDate])
}

model Company {
  id              String               @id @default(cuid())
  name            String               @unique
  slug            String               @unique
  companyType     CompanyType?
  legalName       String?
  taxId           String?
  email           String?
  phone           String?
  website         String?
  /// [Address]
  address         Json?
  logo            String?
  isActive        Boolean              @default(true)
  /// [CompanySettings]
  settings        Json?
  /// [CompanyMetadata]
  metadata        Json?
  parentCompanyId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  accounts        Account[]
  categories      Category[]
  parentCompany   Company?             @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id])
  subsidiaries    Company[]            @relation("CompanyHierarchy")
  creditMemos     CreditMemo[]
  customFields    CompanyCustomField[]
  customers       Customer[]
  customerTypes   CustomerType[]
  delayedCharges  DelayedCharge[]
  delayedCredits  DelayedCredit[]
  emailTemplates  EmailTemplate[]
  estimates       Estimate[]
  files           File[]
  invoices        Invoice[]
  items           Item[]
  journalEntry    JournalEntry[]
  payments        Payment[]
  paymentEvents   PaymentEvent[]
  products        Product[]
  refundReceipts  RefundReceipt[]
  roles           Role[]
  salesReceipts   SalesReceipt[]
  store           Store?
  taxRates        TaxRate[]
  transactions    Transaction[]
  users           UserCompany[]
  tickets         Ticket[]
  activeUsers     User[]               @relation("ActiveCompany")
  accountantAssignments AccountantAssignment[]

  @@index([isActive])
  @@index([parentCompanyId])
}

// Accountant organization: represents an accounting firm or profile that manages multiple client companies.
model Accountant {
  id        String           @id @default(cuid())
  name      String
  slug      String?          @unique
  ownerId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  owner     User?            @relation("AccountantOwner", fields: [ownerId], references: [id])
  users     AccountantUser[]
  assignments AccountantAssignment[]

  @@index([ownerId])
}

// Users that belong to an Accountant profile (accounting staff)
model AccountantUser {
  id           String              @id @default(cuid())
  accountantId String
  userId       String
  role         AccountantUserRole  @default(MEMBER)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  accountant   Accountant          @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments  AccountantAssignment[]

  @@unique([accountantId, userId])
  @@index([accountantId])
  @@index([userId])
}

enum AccountantUserRole {
  OWNER
  ADMIN
  MEMBER
}

// Assignment of an accountant (or accountant user) to a client company with optional per-user permissions
model AccountantAssignment {
  id               String         @id @default(cuid())
  accountantId     String
  accountantUserId String?
  companyId        String
  permissions      Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  accountant       Accountant     @relation(fields: [accountantId], references: [id], onDelete: Cascade)
  accountantUser   AccountantUser? @relation(fields: [accountantUserId], references: [id])
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([accountantId, companyId])
  @@index([accountantId])
  @@index([companyId])
  @@index([accountantUserId])
}


model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Ticket {
  id          String    @id @default(uuid())
  title       String
  service     String?
  channel     String?
  status      String    @default("OPEN")
  companyId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  messages    Message[]
  company     Company?  @relation(fields: [companyId], references: [id])
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@map("ticket")
}

model Message {
  id                 String              @id @default(uuid())
  ticketId           String
  author             String?
  message            String
  type               String              @default("text")
  date               DateTime            @default(now())
  ticket             Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messageAttachments MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum AddressType {
  BILLING
  SHIPPING
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountApplicationTime {
  BEFORE_TAX
  AFTER_TAX
}

enum IntervalUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum TaxStatus {
  ACTIVE
  INACTIVE
}

enum TaxType {
  SALES
  VAT
  GST
  SERVICE
  OTHER
}

enum ReceiptStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

enum AdjustmentStrategy {
  DISTRIBUTE_TO_FUTURE
  APPEND_TO_REMAINING
  LAST_INSTALLMENT
  NEXT_INSTALLMENT
  WEIGHTED_DISTRIBUTION
  PROPORTIONAL_REMAINING
  FIXED_FIRST
  CUSTOM
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
