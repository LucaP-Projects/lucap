  @@index([transactionId])
  @@index([oldCategoryId])
  @@index([newCategoryId])
  @@index([changedBy])
  @@index([changedAt])
}

model Transaction {
  id                  String                  @id @default(cuid())
  date                DateTime                @default(now())
  amount              Float
  approvedBy          String?
  categoryId          String?
  companyId           String
  completed           Boolean                 @default(false)
  completedAt         DateTime?
  createdAt           DateTime                @default(now())
  createdBy           String
  creditMemoId        String?
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  description         String?
  invoicePaymentId    String?
  isActive            Boolean                 @default(true)
  metadata            Json?
  notes               String?
  paymentMethod       PaymentMethod?
  referenceNumber     String?
  refundReceiptId     String?
  salesReceiptId      String?
  type                TransactionType
  updatedAt           DateTime                @updatedAt
  status              TransactionStatus       @default(INCOMPLETE)
  approvedByUser      User?                   @relation("ApprovedTransactions", fields: [approvedBy], references: [id])
  category            TransactionCategory?    @relation("CategoryTransactions", fields: [categoryId], references: [id])
  company             Company                 @relation(fields: [companyId], references: [id])
  createdByUser       User                    @relation("UserTransactions", fields: [createdBy], references: [id])
  creditMemo          CreditMemo?             @relation(fields: [creditMemoId], references: [id])
  invoicePayment      Payment?                @relation(fields: [invoicePaymentId], references: [id])
  refundReceipt       RefundReceipt?          @relation(fields: [refundReceiptId], references: [id])
  salesReceipt        SalesReceipt?           @relation(fields: [salesReceiptId], references: [id])
  attachments         TransactionAttachment[]
  transactionHistory  TransactionHistory[]

  @@index([type])
  @@index([categoryId])
  @@index([date])
  @@index([createdBy])
  @@index([status])
  @@index([completed])
}

model Product {
