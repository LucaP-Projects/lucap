  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, currency])
  @@index([companyId])
}

model ExchangeRate {
  id             String   @id @default(cuid())
  sourceCurrency String
  targetCurrency String
  rate           Float
  asOfDate       DateTime
  source         String   @default("manual")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sourceCurrency, targetCurrency, asOfDate])
}

model DailyExchangeRate {
  id             String   @id @default(cuid())
  rateDate       DateTime
  baseCurrency   String   @default("USD")
  targetCurrency String
  rate           Float
  createdAt      DateTime @default(now())

  @@unique([rateDate, baseCurrency, targetCurrency])
  @@index([rateDate, targetCurrency])
}

enum BudgetType {
  ANNUAL
  MONTHLY
  QUARTERLY
}

model Budget {
  id         String     @id @default(cuid())
  name       String
  budgetType BudgetType @default(ANNUAL)
  fiscalYear Int
  startDate  DateTime
  endDate    DateTime
  companyId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  entries BudgetEntry[]

  @@unique([name, companyId, fiscalYear])
  @@index([companyId])
}

model BudgetEntry {
  id         String  @id @default(cuid())
  budgetId   String
  accountId  String
  customerId String?
  amount     Float

  budget   Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([budgetId, accountId, customerId])
}

model Employee {
  id               String   @id @default(cuid())
  displayName      String
  title            String?
  givenName        String?
  middleName       String?
  familyName       String?
  suffix           String?
  primaryEmail     String?
  primaryPhone     String?
  mobilePhone      String?
  employeeNumber   String?
  ssn              String?
  costRate         Float?
  billableTime     Boolean  @default(false)
  billRate         Float?
  printOnCheckName String?
  /// [Address]
  primaryAddr      Json?
  hiredDate        DateTime?
  releaseDate      DateTime?
  birthDate        DateTime?
  isActive         Boolean  @default(true)
  companyId        String

  company     Company        @relation(fields: [companyId], references: [id])
  timeEntries TimeActivity[]

  @@index([companyId])
}

model TimeActivity {
  id           String   @id @default(cuid())
  employeeId   String
  vendorId     String?
  customerId   String?
  itemId       String?
  date         DateTime
  startTime    DateTime?
  endTime      DateTime?
  duration     Float
  description  String?
  billable     Boolean  @default(true)
  hourlyRate   Float?
  costRate     Float?
  companyId    String

  employee Employee  @relation(fields: [employeeId], references: [id])
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  company  Company   @relation(fields: [companyId], references: [id])

  @@index([employeeId])
  @@index([vendorId])
  @@index([customerId])
  @@index([companyId])
  @@index([date])
}

model Deposit {
  id                String   @id @default(cuid())
  depositNumber     String?
  depositToAccountId String?
  amount            Float
  depositDate       DateTime
  cashBack          Float    @default(0)
  memo              String?
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  depositToAccount Account? @relation(fields: [depositToAccountId], references: [id])

  @@index([companyId])
  @@index([depositDate])
}

model Transfer {
  id              String   @id @default(cuid())
  amount          Float
  transferDate    DateTime
  fromAccountId   String
  toAccountId     String
  memo            String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([transferDate])
}

model CreditCardPayment {
  id                  String   @id @default(cuid())
  txnDate             DateTime
  amount              Float
  bankAccountId       String
  creditCardAccountId String
  vendorId            String?
  privateNote         String?
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  bankAccount       Account? @relation("CreditCardBankAccount", fields: [bankAccountId], references: [id])
  creditCardAccount Account? @relation("CreditCardAccount", fields: [creditCardAccountId], references: [id])
  vendor            Vendor?  @relation(fields: [vendorId], references: [id])
  company           Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([txnDate])
}

model InventoryAdjustment {
  id             String   @id @default(cuid())
  docNumber      String?
  itemId         String
  quantity       Int
  adjustAccountId String?
  privateNote    String?
  date           DateTime
  companyId      String
  createdAt      DateTime @default(now())

  item          Item     @relation(fields: [itemId], references: [id])
  adjustAccount Account? @relation(fields: [adjustAccountId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([itemId])
  @@index([date])
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringTransaction {
  id              String              @id @default(cuid())
  name            String
  templateType    String
  frequency       RecurringFrequency  @default(MONTHLY)
  active          Boolean             @default(true)
  nextDate        DateTime
  endDate         DateTime?
  numberOfDays    Int?
  numberOfOccurrences Int?
  companyId       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([nextDate])
}

model ChangeOrder {
  id          String   @id @default(cuid())
  estimateId  String?
  amount      Float
  description String?
  date        DateTime
  status      String   @default("PENDING")
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model ReimburseCharge {
  id          String   @id @default(cuid())
  customerId  String?
  amount      Float
  expenseDate DateTime
  description String?
  billable    Boolean  @default(true)
  companyId   String
  createdAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  company  Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
}
