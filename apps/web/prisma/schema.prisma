// Model to track transaction category changes (reclassifications)

model TransactionHistory {
  id            String               @id @default(cuid())
  transaction   Transaction          @relation(fields: [transactionId], references: [id])
  transactionId String
  oldCategory   TransactionCategory? @relation("OldCategory", fields: [oldCategoryId], references: [id])
  oldCategoryId String?
  newCategory   TransactionCategory  @relation("NewCategory", fields: [newCategoryId], references: [id])
  newCategoryId String
  changedBy     String // User ID who made the change
  changedAt     DateTime             @default(now())
  notes         String? // Optional notes about the change
  changeType    String               @default("RECLASSIFICATION") // For future expansion of change tracking

  @@index([transactionId])
  @@index([oldCategoryId])
  @@index([newCategoryId])
  @@index([changedBy])
  @@index([changedAt])
}

model Transaction {
  id              String               @id @default(cuid())
  type            TransactionType
  amount          Float
  description     String? // Optional now
  category        TransactionCategory? @relation("CategoryTransactions", fields: [categoryId], references: [id])
  categoryId      String? // Optional to allow incomplete transactions
  date            DateTime             @default(now())
  paymentMethod   PaymentMethod? // Optional now
  referenceNumber String?
  metadata        Json?
  notes           String? // For temporary notes about incomplete transactions
  completed       Boolean              @default(false)
  completedAt     DateTime?

  // Relationships
  createdBy      String
  createdByUser  User                    @relation("UserTransactions", fields: [createdBy], references: [id])
  approvedBy     String?
  approvedByUser User?                   @relation("ApprovedTransactions", fields: [approvedBy], references: [id])
  attachments    TransactionAttachment[]

  status           TransactionStatus @default(INCOMPLETE)
  invoicePaymentId String? // Link to invoice payment
  salesReceiptId   String? // Link to sales receipt
  creditMemoId     String? // Link to credit memo
  refundReceiptId  String? // Link to refund

  // Add relations
  invoicePayment      Payment?             @relation(fields: [invoicePaymentId], references: [id])
  salesReceipt        SalesReceipt?        @relation(fields: [salesReceiptId], references: [id])
  creditMemo          CreditMemo?          @relation(fields: [creditMemoId], references: [id])
  refundReceipt       RefundReceipt?       @relation(fields: [refundReceiptId], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  company             Company              @relation(fields: [companyId], references: [id])
  companyId           String
  isActive            Boolean              @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  transactionHistory  TransactionHistory[]

  @@index([type])
  @@index([categoryId])
  @@index([date])
  @@index([createdBy])
  @@index([status])
  @@index([completed])
}

// E-commerce models

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id               String            @id @default(cuid())
  name             String
  description      String?           @db.Text
  shortDescription String?
  slug             String            @unique
  price            Float
  compareAtPrice   Float? // Optional "regular price" for showing discounts
  sku              String?
  status           ProductStatus     @default(DRAFT)
  inventory        Int? // Optional inventory tracking
  images           ProductImage[]
  categories       CategoryProduct[]
  variants         ProductVariant[]
  features         String[] // Array of product features/bullets
  metadata         Json? // For additional custom fields
  isSubscription   Boolean           @default(false)

  // Subscription specific fields (if applicable)
  billingInterval      String? // monthly, yearly, etc.
  billingIntervalCount Int? // How many intervals (e.g. 3 months)
  trialDays            Int?    @default(0)

  // Accounting integration
  itemId String? // Link to existing accounting Item
  item   Item?   @relation(fields: [itemId], references: [id])

  // Store relation
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String // The provider's company ID
  company   Company  @relation(fields: [companyId], references: [id])

  // Relation to central e-commerce
  centralProductId String? // ID reference to central product catalog

  @@index([storeId])
  @@index([companyId])
  @@index([status])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  name      String
  sku       String?
  price     Float? // If null, use product's price
  inventory Int? // If tracking inventory per variant
  metadata  Json?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@index([productId])
}

model CategoryProduct {
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String

  @@id([categoryId, productId])
  @@index([categoryId])
  @@index([productId])
}

model Store {
  id           String  @id @default(cuid())
  name         String
  description  String? @db.Text
  slug         String  @unique
  logo         String?
  banner       String?
  primaryColor String? // Brand colors for theming
  accentColor  String?

  // Store settings
  isPublic     Boolean @default(true)
  customDomain String? // For custom domains like store.example.com

  // Store owner
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Products in store
  products Product[]

  // Access control - optional if needed
  allowGuests Boolean @default(true)

  // Payments integration
  stripeConnectedAccountId String?
  paymentSettings          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId])
  @@index([companyId])
}

model EmailTemplate {
