generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String        @id @default(uuid())
  email                String        @unique
  name                 String
  password             String?
  emailVerified        Boolean       @default(false)
  image                String?
  role                 UserRole      @default(USER)
  banned               Boolean?
  banReason            String?
  banExpires           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  activeCompanyId      String?
  isActive             Boolean       @default(true)
  deactivatedAt        DateTime?
  deactivatedByUserId  String?
  deactivationReason   String?
  customer             Customer?
  approvedTransactions Transaction[] @relation("ApprovedTransactions")
  createdTransactions  Transaction[] @relation("UserTransactions")
  useraccounts         UserAccount[]
  companies            UserCompany[]
  sessions             Session[]
  tickets              Ticket[]
  formationRequests    CompanyFormationRequest[]
  activeCompany        Company?      @relation("ActiveCompany", fields: [activeCompanyId], references: [id])
  ownedAccountants     Accountant[]  @relation("AccountantOwner")
  accountantProfiles   AccountantUser[]
  @@index([activeCompanyId])
  @@map("users")
}

model UserAccount {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([providerId])
  @@map("UserAccount")
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  isActive  Boolean  @default(true)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([roleId])
  @@index([isActive])
}

model Session {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Role {
  id            String        @id @default(cuid())
  name          String
  description   String?
  systemRole    SystemRole?
  permissions   Permission[]
  companyId     String
  parentRoleId  String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id])
  parentRole    Role?         @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles    Role[]        @relation("RoleHierarchy")
  userCompanies UserCompany[]

  @@unique([name, companyId])
  @@index([companyId])
  @@index([isActive])
  @@index([parentRoleId])
  @@index([systemRole])
}

model Customer {
  id                     String                          @id @default(cuid())
  displayName            String                          @db.VarChar(500)
  title                  String?                         @db.VarChar(16)
  givenName              String?                         @db.VarChar(100)
  middleName             String?                         @db.VarChar(100)
  familyName             String?                         @db.VarChar(100)
  suffix                 String?                         @db.VarChar(16)
  companyName            String?                         @db.VarChar(100)
  customerTypeId         String?
  primaryPhone           String?                         @db.VarChar(30)
  alternatePhone         String?                         @db.VarChar(30)
  mobile                 String?                         @db.VarChar(30)
  fax                    String?                         @db.VarChar(30)
  primaryEmail           String?
  webAddress             String?                         @db.VarChar(1000)
  /// [Address]
  billingAddress         Json?
  /// [Address]  
  shippingAddress        Json?
  taxIdentifier          String?
  secondaryTaxId         String?
  resaleNumber           String?                         @db.VarChar(16)
  businessNumber         String?                         @db.VarChar(10)
  notes                  String?                         @db.VarChar(2000)
  balance                Float                           @default(0)
  creditLimit            Float?
  preferredPaymentMethod CustomerPreferredPaymentMethod?
  taxable                Boolean                         @default(true)
  printOnCheckName       String?                         @db.VarChar(110)
  parentId               String?
  level                  Int                             @default(0)
  status                 CustomerStatus                  @default(ACTIVE)
  /// [CustomerMetadata]
  metadata               Json?
  userId                 String?                         @unique
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  companyId               String
  isActive                Boolean                 @default(true)
  deactivatedAt          DateTime?
  deactivatedByUserId    String?
  deactivationReason     String?
  creditMemos            CreditMemo[]
  company                Company                         @relation(fields: [companyId], references: [id])
  customerType           CustomerType?                   @relation("CustomerType", fields: [customerTypeId], references: [id])
  parentCustomer         Customer?                       @relation("CustomerHierarchy", fields: [parentId], references: [id])
  subCustomers           Customer[]                      @relation("CustomerHierarchy")
  user                   User?                           @relation(fields: [userId], references: [id])
  customerPaymentEvents  CustomerPaymentEvent[]
  delayedCharges         DelayedCharge[]
  delayedCredits         DelayedCredit[]
  estimates              Estimate[]
  invoices               Invoice[]
  journalEntry           JournalEntry[]
  payments               Payment[]
  refundReceipts         RefundReceipt[]
  salesReceipts          SalesReceipt[]
  timeActivities         TimeActivity[]
  budgetEntries          BudgetEntry[]
  reimburseCharges       ReimburseCharge[]

  @@unique([displayName, companyId])
  @@index([parentId])
  @@index([status])
  @@index([displayName])
}

model CustomerType {
  id        String     @id @default(cuid())
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  companyId String
  customer  Customer[] @relation("CustomerType")
  company   Company    @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
}

model Account {
  id                  String             @id @default(cuid())
  title               String
  number              String
  composed_number     String
  is_custom           Boolean            @default(false)
  is_active           Boolean            @default(true)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  parent_id           String?
  templateId          String?
  companyId           String
  isActive            Boolean            @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent              Account?           @relation("AccountToAccount", fields: [parent_id], references: [id])
  children            Account[]          @relation("AccountToAccount")
  template            AccountTemplate?   @relation(fields: [templateId], references: [id])
  expenseItems        Item[]             @relation("ItemExpenseAccount")
  incomeItems         Item[]             @relation("ItemIncomeAccount")
  inventoryAssetItems Item[]             @relation("ItemInventoryAssetAccount")
  journalEntryLine        JournalEntryLine[]
  billLineItems           BillLineItem[]
  purchaseLineItems       PurchaseLineItem[]
  purchaseOrderLineItems  PurchaseOrderLineItem[]
  purchases               Purchase[]              @relation("PurchaseAccountRef")
  purchaseOrders          PurchaseOrder[]          @relation("PurchaseOrderApAccountRef")
  vendorCreditLineItems   VendorCreditLineItem[]
  budgetEntries           BudgetEntry[]
  deposits                Deposit[]
  creditCardBankAccounts  CreditCardPayment[]  @relation("CreditCardBankAccount")
  creditCardAccounts      CreditCardPayment[]  @relation("CreditCardAccount")
  inventoryAdjustments    InventoryAdjustment[]

  @@unique([companyId, number])
  @@unique([companyId, composed_number])
  @@index([parent_id])
  @@index([templateId])
  @@index([companyId])
}

model PaymentEvent {
  id                    String                 @id @default(cuid())
  type                  PaymentFrequency
  active                Boolean                @default(true)
  versionId             String?                @unique
  updatedAt             DateTime               @updatedAt
  createdAt             DateTime               @default(now())
  companyId             String
  isActive              Boolean                @default(true)
  deactivatedAt         DateTime?
  deactivatedByUserId   String?
  deactivationReason    String?
  customerPaymentEvents CustomerPaymentEvent[]
  company               Company                @relation(fields: [companyId], references: [id])
  currentVersion        PaymentEventVersion?   @relation("CurrentVersion", fields: [versionId], references: [id])
  versions              PaymentEventVersion[]  @relation("AllVersions")

  @@index([active])
  @@index([versionId])
}

model PaymentEventVersion {
  id                      String                 @id @default(cuid())
  paymentEventId          String?
  version                 Int
  name                    String
  description             String?
  type                    PaymentFrequency
  status                  VersionStatus          @default(DRAFT)
  scheduledActivationDate DateTime?
  activatedAt             DateTime?
  /// [PaymentSettings]
  paymentSettings         Json
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  isActive                Boolean                @default(true)
  deactivatedAt           DateTime?
  deactivatedByUserId     String?
  deactivationReason      String?
  customerPaymentEvents   CustomerPaymentEvent[]
  currentForPaymentEvent  PaymentEvent?          @relation("CurrentVersion")
  items                   PaymentEventItem[]
  paymentEvent            PaymentEvent?          @relation("AllVersions", fields: [paymentEventId], references: [id])

  @@unique([paymentEventId, version])
  @@index([paymentEventId])
  @@index([type])
}

model CustomerPaymentEvent {
  id                  String              @id @default(cuid())
  paymentEventId      String
  versionId           String
  customerId          String?
  startDate           DateTime
  endDate             DateTime?
  status              PaymentStatus       @default(PENDING)
  credit              Float               @default(0)
  /// [PaymentProgress]
  progress            Json
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isActive            Boolean             @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  customer            Customer?           @relation(fields: [customerId], references: [id])
  paymentEvent        PaymentEvent        @relation(fields: [paymentEventId], references: [id])
  version             PaymentEventVersion @relation(fields: [versionId], references: [id])
  invoices            Invoice[]

  @@index([customerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model PaymentEventItem {
  id                  String              @id @default(cuid())
  versionId           String
  productName         String
  description         String?
  quantity            Float
  rate                Float
  sku                 String?
  amount              Float
  taxable             Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  itemId              String?
  isActive            Boolean             @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  item                Item?               @relation(fields: [itemId], references: [id])
  version             PaymentEventVersion @relation(fields: [versionId], references: [id])

  @@index([versionId])
}

model Category {
  id                  String            @id @default(cuid())
  name                String            @db.VarChar(50)
  description         String?           @db.VarChar(200)
  parentId            String?
  level               Int               @default(0)
  sortOrder           Int               @default(0)
  active              Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  companyId           String
  isActive            Boolean           @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  company             Company           @relation(fields: [companyId], references: [id])
  parent              Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories       Category[]        @relation("CategoryHierarchy")
  items               Item[]

  @@index([name, companyId])
  @@index([parentId])
  @@index([active])
  @@index([level])
  @@index([sortOrder])
}

model Item {
  id                      String                   @id @default(cuid())
  type                    ItemType
  name                    String                   @db.VarChar(100)
  sku                     String?                  @db.VarChar(50)
  categoryId              String?
  description             String?                  @db.VarChar(1000)
  salesDescription        String?                  @db.VarChar(1000)
  purchaseDescription     String?                  @db.VarChar(1000)
  sellable                Boolean                  @default(true)
  salesPrice              Float                    @default(0.00)
  salesTaxable            Boolean                  @default(true)
  salesStartDate          DateTime?
  salesEndDate            DateTime?
  discountEnabled         Boolean                  @default(false)
  discountType            DiscountType?
  discountValue           Float?
  discountApplicationTime DiscountApplicationTime?
  discountAmount          Float                    @default(0)
  purchasable             Boolean                  @default(false)
  cost                    Float?
  preferredVendorId       String?
  lastPurchasePrice       Float?
  lastPurchaseDate        DateTime?
  trackInventory          Boolean                  @default(false)
  quantityOnHand          Int?
  reorderPoint            Int?
  initialQuantity         Int?
  asOfDate                DateTime?
  incomeAccountId         String?
  expenseAccountId        String?
  inventoryAssetAccountId String?
  imageUrl                String?                  @db.VarChar(2000)
  /// [ItemMetadata]
  metadata                Json?
  status                  ItemStatus               @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  companyId               String
  isActive                Boolean                  @default(true)
  deactivatedAt           DateTime?
  deactivatedByUserId     String?
  deactivationReason      String?

  // Store fields (single source of truth)
  storeStatus             StoreItemStatus          @default(DRAFT)
  storeSlug               String?
  storeDescription        String?                  @db.VarChar(2000)
  storeShortDescription   String?                  @db.VarChar(500)
  /// [StoreItemImages]
  storeImages             Json?
  storeFeatures           String[]
  storeIsPublic           Boolean                  @default(false)
  storeCategoryIds        String[]

  // Relations
  creditMemoItems         CreditMemoItem[]
  chargeItems             DelayedChargeItem[]
  creditItems             DelayedCreditItem[]
  estimateItems           EstimateItem[]
  invoiceItems            InvoiceItem[]
  category                Category?                @relation(fields: [categoryId], references: [id])
  company                 Company                  @relation(fields: [companyId], references: [id])
  expenseAccount          Account?                 @relation("ItemExpenseAccount", fields: [expenseAccountId], references: [id])
  incomeAccount           Account?                 @relation("ItemIncomeAccount", fields: [incomeAccountId], references: [id])
  inventoryAssetAccount   Account?                 @relation("ItemInventoryAssetAccount", fields: [inventoryAssetAccountId], references: [id])
  paymentEventItems       PaymentEventItem[]
  refundItems             RefundReceiptItem[]
  salesReceiptItems       SalesReceiptItem[]
  cartItems               CartItem[]
  orderItems              OrderItem[]
  inventoryAdjustments    InventoryAdjustment[]

  @@unique([sku, companyId])
  @@unique([storeSlug, companyId])
  @@index([type])
  @@index([status])
  @@index([categoryId])
  @@index([sku])
  @@index([sellable])
  @@index([purchasable])
  @@index([trackInventory])
  @@index([companyId])
  @@index([storeStatus])
  @@index([storeIsPublic])
  @@index([storeSlug])
}

model InvoiceItem {
  id                  String    @id @default(cuid())
  invoiceId           String
  productName         String
  description         String?
  quantity            Float
  rate                Float
  amount              Float
  sku                 String?
  taxable             Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  itemId              String?
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  invoice             Invoice   @relation(fields: [invoiceId], references: [id])
  item                Item?     @relation(fields: [itemId], references: [id])

  @@index([invoiceId])
}

model Invoice {
  id                      String                   @id @default(cuid())
  convertedFromEstimate   Boolean                  @default(false)
  estimateId              String?
  number                  String
  customerId              String
  paymentEventId          String?
  discountType            DiscountType?
  discountValue           Float?
  taxRate                 Float                    @default(0)
  discountApplicationTime DiscountApplicationTime?
  discountAmount          Float                    @default(0)
  amount                  Float
  dueDate                 DateTime
  status                  PaymentStatus            @default(PENDING)
  notes                   String?
  emailCustomer           String?
  taxId                   String?
  taxAmount               Float                    @default(0)
  /// [PaymentEventSnapshot]
  paymentEventSnapshot    Json
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  isLinkedToVersion       Boolean                  @default(false)
  companyId               String
  classId                 String?
  departmentId            String?
  isActive                Boolean                  @default(true)
  deactivatedAt           DateTime?
  deactivatedByUserId     String?
  deactivationReason      String?
  currency                String                   @default("TND")
  exchangeRateId          String?
  creditMemo              CreditMemo[]
  company                 Company                  @relation(fields: [companyId], references: [id])
  customer                Customer                 @relation(fields: [customerId], references: [id])
  estimate                Estimate?                @relation(fields: [estimateId], references: [id])
  customerPaymentEvent    CustomerPaymentEvent?    @relation(fields: [paymentEventId], references: [id])
  tax                     TaxRate?                 @relation(fields: [taxId], references: [id])
  class                   Class?                   @relation(fields: [classId], references: [id])
  department              Department?              @relation(fields: [departmentId], references: [id])
  attachments             InvoiceAttachment[]
  items                   InvoiceItem[]
  payments                Payment[]
  order                   Order?

  @@unique([number, companyId])
  @@index([estimateId])
  @@index([customerId])
  @@index([paymentEventId])
  @@index([status])
  @@index([dueDate])
  @@index([classId])
  @@index([departmentId])
}

model InvoiceAttachment {
  id                  String    @id @default(cuid())
  invoiceId           String
  fileId              String
  createdAt           DateTime  @default(now())
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  file                File      @relation(fields: [fileId], references: [id])
  invoice             Invoice   @relation(fields: [invoiceId], references: [id])

  @@unique([invoiceId, fileId])
  @@index([invoiceId])
  @@index([fileId])
}

model EstimateItem {
  id                  String    @id @default(cuid())
  estimateId          String
  productName         String
  description         String?
  quantity            Float
  rate                Float
  amount              Float
  sku                 String?
  taxable             Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  itemId              String?
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  estimate            Estimate  @relation(fields: [estimateId], references: [id])
  item                Item?     @relation(fields: [itemId], references: [id])

  @@index([estimateId])
}

model Estimate {
  id                      String                   @id @default(cuid())
  number                  String
  customerId              String
  amount                  Float
  dueDate                 DateTime
  taxRate                 Float                    @default(0)
  discountType            DiscountType?
  discountValue           Float?
  discountApplicationTime DiscountApplicationTime?
  discountAmount          Float                    @default(0)
  status                  EstimateStatus           @default(DRAFT)
  notes                   String?
  emailCustomer           String?
  taxId                   String?
  taxAmount               Float                    @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  validUntil              DateTime?
  convertedToInvoice      Boolean                  @default(false)
  invoiceId               String?
  /// [PaymentEventSnapshot]
  paymentEventSnapshot    Json
  companyId               String
  isActive                Boolean                  @default(true)
  deactivatedAt           DateTime?
  deactivatedByUserId     String?
  deactivationReason      String?
  currency                String                   @default("TND")
  exchangeRateId          String?
  company                 Company                  @relation(fields: [companyId], references: [id])
  customer                Customer                 @relation(fields: [customerId], references: [id])
  tax                     TaxRate?                 @relation(fields: [taxId], references: [id])
  attachments             EstimateAttachment[]
  items                   EstimateItem[]
  invoices                Invoice[]

  @@unique([number, companyId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model EstimateAttachment {
  id                  String    @id @default(cuid())
  estimateId          String
  fileId              String
  createdAt           DateTime  @default(now())
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  estimate            Estimate  @relation(fields: [estimateId], references: [id])
  file                File      @relation(fields: [fileId], references: [id])

  @@unique([estimateId, fileId])
  @@index([estimateId])
  @@index([fileId])
}

model CreditMemoItem {
  id                  String     @id @default(cuid())
  creditMemoId        String
  productName         String
  description         String?
  quantity            Float
  sku                 String?
  rate                Float
  amount              Float
  taxable             Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  itemId              String?
  isActive            Boolean    @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  creditMemo          CreditMemo @relation(fields: [creditMemoId], references: [id])
  item                Item?      @relation(fields: [itemId], references: [id])

  @@index([creditMemoId])
}

model CreditMemo {
  id                      String                   @id @default(cuid())
  number                  String
  dueDate                 DateTime
  customerId              String
  discountType            DiscountType?
  discountValue           Float?
  discountApplicationTime DiscountApplicationTime?
  discountAmount          Float                    @default(0)
  taxRate                 Float                    @default(0)
  amount                  Float
  taxId                   String?
  taxAmount               Float                    @default(0)
  issueDate               DateTime                 @default(now())
  reason                  CreditMemoReason         @default(OTHER)
  status                  CreditMemoStatus         @default(DRAFT)
  notes                   String?
  /// [PaymentEventSnapshot]
  paymentEventSnapshot    Json
  emailCustomer           String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  companyId               String
  invoiceId               String?
  isActive                Boolean                  @default(true)
  deactivatedAt           DateTime?
  deactivatedByUserId     String?
  deactivationReason      String?
  currency                String                   @default("TND")
  exchangeRateId          String?
  company                 Company                  @relation(fields: [companyId], references: [id])
  customer                Customer                 @relation(fields: [customerId], references: [id])
  invoice                 Invoice?                 @relation(fields: [invoiceId], references: [id])
  tax                     TaxRate?                 @relation(fields: [taxId], references: [id])
  attachments             CreditMemoAttachment[]
  items                   CreditMemoItem[]
  transactions            Transaction[]

  @@unique([number, companyId])
  @@index([customerId])
  @@index([status])
  @@index([issueDate])
}

model CreditMemoAttachment {
  id                  String     @id @default(cuid())
  creditMemoId        String
  fileId              String
  createdAt           DateTime   @default(now())
  isActive            Boolean    @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  creditMemo          CreditMemo @relation(fields: [creditMemoId], references: [id])
  file                File       @relation(fields: [fileId], references: [id])

  @@unique([creditMemoId, fileId])
  @@index([creditMemoId])
  @@index([fileId])
}

model SalesReceiptItem {
  id                  String       @id @default(cuid())
  receiptId           String
  productName         String
  description         String?
  quantity            Float
  rate                Float
  sku                 String?
  amount              Float
  taxable             Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  itemId              String?
  isActive            Boolean      @default(true)
  deactivatedAt       DateTime?
  deactivatedByUserId String?
  deactivationReason  String?
  item                Item?        @relation(fields: [itemId], references: [id])
  receipt             SalesReceipt @relation(fields: [receiptId], references: [id])

  @@index([receiptId])
}

model SalesReceipt {
  id                      String                   @id @default(cuid())
  number                  String
  dueDate                 DateTime
  customerId              String
  discountType            DiscountType?
  discountValue           Float?
  discountApplicationTime DiscountApplicationTime?
  discountAmount          Float                    @default(0)
  taxId                   String?
  /// [PaymentEventSnapshot]
  paymentEventSnapshot    Json
  taxAmount               Float                    @default(0)
  taxRate                 Float                    @default(0)
  amount                  Float
  paymentMethod           PaymentMethod
  paymentRef              String?
  notes                   String?
  emailCustomer           String?
  status                  ReceiptStatus            @default(COMPLETED)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  companyId               String
  isActive                Boolean                  @default(true)
  deactivatedAt           DateTime?
  deactivatedByUserId     String?
  deactivationReason      String?
  currency                String                   @default("TND")
  exchangeRateId          String?
  attachments             ReceiptAttachment[]
