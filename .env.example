# Better Auth configuration
BETTER_AUTH_SECRET=replace_this_with_a_32+_char_high_entropy_secret
BETTER_AUTH_URL=http://localhost:3000

# Database connection (example for Prisma)
DATABASE_URL=postgresql://lucap:lucap_pass@localhost:5432/lucap
# Postgres
POSTGRES_USER=lucap
POSTGRES_PASSWORD=lucap_pass
POSTGRES_DB=lucap

# MinIO (S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
FILE_UPLOAD_MAX_SIZE=5242880

# STORAGE_ENCRYPTION_KEY must be a cryptographically secure 32-byte hex string (64 characters)
STORAGE_ENCRYPTION_KEY=replace_this_with_a_secure_encryption_key
GARAGE_RPC_SECRET=replace_this_with_a_secure_rpc_secret
GARAGE_ENDPOINT=replace_this_with_your_garage_endpoint
GARAGE_REGION=replace_this_with_your_garage_region
GARAGE_ACCESS_KEY_ID=replace_this_with_your_garage_access_key_id
GARAGE_SECRET_ACCESS_KEY=replace_this_with_your_garage_secret_access_key
GARAGE_BUCKET_NAME=replace_this_with_your_garage_bucket_name
GARAGE_PUBLIC_URL=replace_this_with_your_garage_public_url