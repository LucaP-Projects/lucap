{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "kysely": "^0.28.17"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.5",
    "@types/lodash": "^4.17.24",
    "@types/lodash.debounce": "^4.0.9",
    "ai": "^7.0.11",
    "date-fns": "^4.4.0",
    "lodash": "^4.18.1",
    "lodash.debounce": "^4.0.8"
  }
